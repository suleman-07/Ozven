// This is your Prisma schema file.
// Production-ready schema for the packaging website admin panel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Admin {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Industry {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model BoxStyle {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Material {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Finish {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  slug          String        @unique
  description   String?
  featuredImage String?
  status        ProductStatus @default(ACTIVE)
  categoryId    String        @db.Uuid
  industryId    String        @db.Uuid
  boxStyleId    String        @db.Uuid
  materialId    String        @db.Uuid
  finishId      String        @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  industry Industry @relation(fields: [industryId], references: [id])
  boxStyle BoxStyle @relation(fields: [boxStyleId], references: [id])
  material Material @relation(fields: [materialId], references: [id])
  finish   Finish   @relation(fields: [finishId], references: [id])

  images ProductImage[]
  quotes QuoteRequest[]

  @@index([name])
  @@index([status])
  @@index([categoryId])
  @@index([industryId])
  @@index([boxStyleId])
  @@index([materialId])
  @@index([finishId])
}

model ProductImage {
  id           String   @id @default(uuid()) @db.Uuid
  imageUrl     String
  productId    String   @db.Uuid
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model QuoteRequest {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String
  message   String
  productId String?  @db.Uuid
  createdAt DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([phone])
}
